# Secrets — NEVER commit
.env
.env.local

# Local runtime state — regenerated on each run
code/state/sessions/*/
!code/state/sessions/.gitkeep
code/sandbox/*.txt
code/.venv/
gateway/.venv/
gateway/*.db
gateway/usage.json

# Build / cache artifacts
**/__pycache__/
**/*.pyc
**/uv.lock
**/.pytest_cache/

# Editors
.vscode/
.idea/
.DS_Store
# Python tooling
.mypy_cache/
.coverage
.tox/
.nox/
.cache/
